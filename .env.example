# Copy to .env and fill in values, then restart:
#   cp .env.example .env

# Required for PDF export (PDFBolt) — get from https://pdfbolt.com or Vercel env
PDFBOLT_API_KEY=

# PDFBolt webhook signing secret (for verifying async webhook callbacks)
# PDFBOLT_WEBHOOK_SECRET=

# Required for Copy Link (uploads PDF to Supabase Storage)
# Supabase → Settings → API → service_role (secret)
# SUPABASE_SERVICE_ROLE_KEY=

# Optional locally (required in production). From Supabase → Settings → API → JWT Secret
# SUPABASE_JWT_SECRET=

# Optional override (defaults to the project URL baked into the app)
# SUPABASE_URL=https://wiudrzdkbpyziaodqoog.supabase.co

# API server port (Vite proxies /api here)
PORT=8080
NODE_ENV=development
PDF_LOCAL_DEV=1
